# Host port for the Icecast stream server
SLEEPNOISE_PORT=8010
# Host port for the control app (web UI + API)
APP_PORT=8011
# Base URL Sonos uses to pull the streams: http://<host-lan-ip>:<SLEEPNOISE_PORT>
STREAM_BASE_URL=http://192.168.1.10:8010
# Default Sonos room name used when API calls omit "speaker" (e.g. iOS shortcut)
DEFAULT_ROOM=
# Safety cap for volume set through the app (percent)
MAX_VOLUME=40
# Optional comma-separated Sonos IPs, skips multicast discovery if set
SONOS_IPS=
# Icecast credentials (generate your own, e.g. openssl rand -hex 12)
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme
ICECAST_RELAY_PASSWORD=changeme
